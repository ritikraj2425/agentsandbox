# ============================================================================
# AgentSandbox .gitignore
# ============================================================================
# This file tells Git which files and folders to IGNORE (not track).
# Ignored files won't show up in `git status` and won't be pushed to GitHub.
#
# Rule of thumb: ignore anything that is GENERATED (not written by a human).
# Source code = tracked. Build output / logs / caches = ignored.
# ============================================================================
.env
# --------------------------------------------------------------------------
# Run data (generated by `agentsandbox run`)
# --------------------------------------------------------------------------
# Every run creates .agentsandbox/runs/<run_id>/ with trace.jsonl,
# stdout.log, stderr.log, and report.json. This is local debug data —
# it changes every time you run a command and should NOT be in the repo.
.agentsandbox/

# --------------------------------------------------------------------------
# Go build artifacts
# --------------------------------------------------------------------------
# `go build` compiles your code into a binary. The binary name matches
# the directory name (e.g., `agentsandbox` from cmd/agentsandbox/).
# Binaries are platform-specific (macOS binary won't run on Linux),
# so they should never be committed.
/agentsandbox
*.exe

# Go test generates temporary binaries and coverage files.
# *.test = compiled test binaries (from `go test -c`)
# *.out  = coverage/profiling output (from `go test -coverprofile`)
*.test
*.out

# --------------------------------------------------------------------------
# OS-generated files
# --------------------------------------------------------------------------
# macOS creates .DS_Store in every folder you open in Finder.
# It stores folder view preferences (icon size, sort order, etc.).
# Completely useless in a code repository.
.DS_Store

# Thumbnail caches on macOS and Windows.
Thumbs.db

# --------------------------------------------------------------------------
# Editor and IDE files
# --------------------------------------------------------------------------
# These contain YOUR personal editor settings (font size, theme, etc.).
# Each developer has their own preferences — committing these causes
# constant merge conflicts and clutters the repo.
.vscode/
.idea/
*.swp
*.swo
*~

# --------------------------------------------------------------------------
# Go module cache (rare, but just in case)
# --------------------------------------------------------------------------
# The Go module cache is stored globally at ~/go/pkg/mod/ by default.
# Some setups place it locally — ignore it if so.
vendor/

# Go build cache
.gocache/

