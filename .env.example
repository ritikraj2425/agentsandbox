# AgentSandbox gateway settings
AGENTSANDBOX_PORT=8080
AGENTSANDBOX_MAX_SESSIONS=1000
AGENTSANDBOX_AUTH_KEY=dev-secret-change-me
AGENTSANDBOX_CORS_ORIGIN=http://localhost:3000

# Optional. Leave empty to use the legacy static AGENTSANDBOX_AUTH_KEY auth path.
# For production, use Postgres and generate real API keys with:
# go run ./cmd/agentsandbox admin create-key --db-url "$DATABASE_URL" --email you@example.com --name default
DATABASE_URL=
