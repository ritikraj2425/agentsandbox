# Browser-visible gateway URL used by dashboard API calls.
NEXT_PUBLIC_API_URL=http://localhost:8080/v1

# Browser-visible host used for websocket event streams, without ws:// or wss://.
NEXT_PUBLIC_WS_HOST=localhost:8080

# Used by dashboard API routes that need database access.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agentsandbox?sslmode=disable


#for production
AGENTSANDBOX_AUTH_KEY=<real-secret-or-admin-bootstrap-key>
AGENTSANDBOX_CORS_ORIGIN=https://your-dashboard-domain.com
DATABASE_URL=<prod-postgres-url>
NEXT_PUBLIC_API_URL=https://your-api-domain.com/v1
NEXT_PUBLIC_WS_HOST=your-api-domain.com